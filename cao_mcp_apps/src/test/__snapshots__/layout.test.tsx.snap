exports[`dashboard container-query layout > renders the grid and all cards with no truncation at 350px > dashboard-grid-350 1`] = `"<div class="cao-card" data-testid="agent-card" data-terminal-id="term0"><div class="cao-card-head"><span class="cao-card-title">agent-0-with-a-very-long-name-that-must-wrap-not-truncate</span><span class="cao-status cao-status-idle" data-testid="status-badge" title="Idle">idle</span></div><dl class="cao-card-meta"><div><dt>provider</dt><dd>kiro_cli</dd></div><div><dt>session</dt><dd>cao-x</dd></div></dl></div><div class="cao-card" data-testid="agent-card" data-terminal-id="term1"><div class="cao-card-head"><span class="cao-card-title">agent-1-with-a-very-long-name-that-must-wrap-not-truncate</span><span class="cao-status cao-status-idle" data-testid="status-badge" title="Idle">idle</span></div><dl class="cao-card-meta"><div><dt>provider</dt><dd>kiro_cli</dd></div><div><dt>session</dt><dd>cao-x</dd></div></dl></div><div class="cao-card" data-testid="agent-card" data-terminal-id="term2"><div class="cao-card-head"><span class="cao-card-title">agent-2-with-a-very-long-name-that-must-wrap-not-truncate</span><span class="cao-status cao-status-idle" data-testid="status-badge" title="Idle">idle</span></div><dl class="cao-card-meta"><div><dt>provider</dt><dd>kiro_cli</dd></div><div><dt>session</dt><dd>cao-x</dd></div></dl></div>"`;

